@page "/fashionapi"
@rendermode InteractiveServer

<PageTitle>fashion search api</PageTitle>

<h1>fashion search</h1>

<h3>Build Visual Search Index</h3>

<button @onclick="BuildVisualSearchIndex">Build Index</button>

<p>@statusMessage</p>

@code {
    private string statusMessage = "";

    private async Task BuildVisualSearchIndex()
    {
        string apiKey = "your_api_key_here"; // Your IBM API key
        string catalogName = "my_catalog";
        string baseUrl = "https://api.cognitivefashion.ibm.com/v1/catalog/";

        using (HttpClient client = new HttpClient())
        {
            client.DefaultRequestHeaders.Add("X-Api-Key", apiKey);

            string url = $"{baseUrl}{catalogName}/visual_search_index?per_category_index=true&full_index=true&group_by=true&group_by_k=5";

            HttpResponseMessage response = await client.PostAsync(url, null);

            if (response.IsSuccessStatusCode)
            {
                string result = await response.Content.ReadAsStringAsync();
                statusMessage = $"Index building started: {result}";
            }
            else
            {
                statusMessage = $"Error: {response.StatusCode}";
            }
        }
    }
}