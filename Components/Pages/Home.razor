@page "/"

@inject IWeather WeatherService
@inject Asos AsosService
@inject IJSRuntime JS

<PageTitle>Home</PageTitle>

<section class="hero @(showResults ? "is-result" : "is-search")">
    <div class="hero-image">
        <img src="/images/hero1.jpg" />
    </div>
    <div class="hero-inner">

        @if (!showResults)
        {
            <div class="hero-intro">
                <span class="hero-label">FASHION × WEATHER</span>

                <h1>STYLE FORECAST</h1>

                <p class="hero-subtitle">
                    Weather-powered outfit recommendations.
                </p>

                <div class="search-city">
                    <input @bind="city" placeholder="Enter city..." />
                    <button @onclick="GetWeather">Show Weather</button>
                </div>
            </div>
        }

        @if (showResults && weather != null)
        {
            <div class="hero-result">

                <div class="weather-card">

                    <div class="weather-top">
                        <span>CURRENT WEATHER</span>
                        <span>@weather.City</span>
                    </div>

                    <div class="weather-temp">
                        @Math.Round(weather.Temperature)°
                    </div>

                    <div class="weather-condition">
                        @weather.Condition
                    </div>

                    <div class="weather-grid">
                        <div>
                            <span>Current Time</span>
                            <p>@weather.CurrentTime.ToString("h:mm tt")</p>
                        </div>
                        <div>
                            <span>Sunrise</span>
                            <p>@weather.Sunrise.ToString("h:mm tt")</p>
                        </div>

                        <div>
                            <span>Sunset</span>
                            <p>@weather.Sunset.ToString("h:mm tt")</p>
                        </div>

                        <div>
                            <span>Humidity</span>
                            <p>@weather.Humidity%</p>
                        </div>
                    </div>

                    <div class="weather-message">
                        @GetOutfitSuggestion(weather.Temperature, weather.ConditionType)
                    </div>
                    @if (showResults)

                    {
                        <button class="weather-search-btn" @onclick="Reset">
                            ← New Search
                        </button>
                    }
                    </div>
                
            </div>
        }

    </div>

</section>

@if (showResults)
{
    <section class="results-section">

        <h2>Recommended Wardrobe Staples</h2>

        <div class="controls-row">

            @* <input @bind="nameFilter" placeholder="Filter by name" /> *@
            <input class="filter-input"
                   @bind="nameFilter"
                   placeholder="Filter by name" />
            @* <input @bind="colourFilter" placeholder="Filter by colour" /> *@
            <input class="filter-input"
                   @bind="colourFilter"
                   placeholder="Filter by colour" />

            <select class="filter-select"
                    @onchange="SortChanged">
                <option value="">Sort</option>
                <option value="priceAsc">Price ↑</option>
                <option value="priceDesc">Price ↓</option>
                <option value="nameAsc">Name A-Z</option>
                <option value="nameDesc">Name Z-A</option>
            </select>

            @* <select @onchange="SortChanged">
                <option value="">Sort</option>
                <option value="priceAsc">Price ↑</option>
                <option value="priceDesc">Price ↓</option>
                <option value="nameAsc">Name A-Z</option>
                <option value="nameDesc">Name Z-A</option>
            </select> *@

            @* <button @onclick="ApplyFiltersAndSort">Apply</button>
            <button @onclick="ClearFilters">Clear</button> *@
            <button class="filter-btn"
                    @onclick="ApplyFiltersAndSort">
                Apply
            </button>

            <button class="filter-btn filter-btn-secondary"
                    @onclick="ClearFilters">
                Clear
            </button>

        </div>

        @if (displayedItems != null && displayedItems.Count > 0)
        {
            <div class="product-grid">

                @foreach (var item in displayedItems)
                {
                    <div class="product-card">

                        <a href="@(item.ProductUrl.StartsWith("http")
                                                       ? item.ProductUrl
                                                       : "https://www.asos.com" + item.ProductUrl)"
               target="_blank">

                            <img src="@item.ImageUrl" />
                        </a>

                        <h3>@item.Name</h3>
                        <p>@item.Brand</p>
                        <p>@item.Price</p>

                        <button @onclick="() => SaveToLookbook(item)">
                            Save
                        </button>

                    </div>
                }

            </div>
        }

    </section>
}

@code {

    private string city;
    private WeatherClass weather;

    private List<StyleItem> outfitItems = new();
    private List<StyleItem> displayedItems = new();

    private string currentSort = "";
    private string nameFilter = "";
    private string colourFilter = "";

    private bool showResults = false;

    private async Task GetWeather()
    {
        showResults = false;

        weather = await WeatherService.GetWeatherForCityAsync(city);

        if (weather != null)
        {
            outfitItems = await AsosService.GetStyleForWeatherAsync(weather);
            displayedItems = outfitItems.ToList();
            showResults = true;
        }
    }

    private void Reset()
    {
        showResults = false;
        city = "";
    }

    private string GetOutfitSuggestion(double temp, WeatherCondition conditionType)
    {
        string tempMessage =
            temp <= 5 ? "It's freezing so grab a jacket." :
            temp <= 15 ? "Chilly so best to wear light layers." :
            temp <= 25 ? "Mild so wear anything breathable." :
            "Hot — keep it light.";

        string conditionMessage = conditionType switch
        {
            WeatherCondition.Rainy => "Bring an umbrella.",
            WeatherCondition.Snowy => "Wear warm gear.",
            WeatherCondition.Cloudy => "Layer lightly.",
            WeatherCondition.Sunny => "Sunglasses recommended.",
            _ => ""
        };

        return $"{tempMessage} {conditionMessage}";
    }

    private void ApplyFiltersAndSort()
    {
        var filtered = outfitItems.Where(item =>
        {
            bool nameOk =
                string.IsNullOrWhiteSpace(nameFilter) ||
                item.Name?.Contains(nameFilter, StringComparison.OrdinalIgnoreCase) == true;

            bool colourOk =
                string.IsNullOrWhiteSpace(colourFilter) ||
                item.Colour?.Contains(colourFilter, StringComparison.OrdinalIgnoreCase) == true;

            return nameOk && colourOk;
        }).ToList();

        displayedItems = currentSort switch
        {
            "priceAsc" => filtered.OrderBy(x => ParsePrice(x.Price)).ToList(),
            "priceDesc" => filtered.OrderByDescending(x => ParsePrice(x.Price)).ToList(),
            "nameAsc" => filtered.OrderBy(x => x.Name).ToList(),
            "nameDesc" => filtered.OrderByDescending(x => x.Name).ToList(),
            _ => filtered
        };
    }

    // private async Task SortChanged(ChangeEventArgs e)
    //     => currentSort = e.Value?.ToString() ?? "";

    private async Task SortChanged(ChangeEventArgs e)
    {
        currentSort = e.Value?.ToString() ?? "";
        ApplyFiltersAndSort();
    }
    private decimal ParsePrice(string price)
    {
        if (string.IsNullOrWhiteSpace(price))
            return decimal.MaxValue;

        var cleaned = new string(price.Where(c => char.IsDigit(c) || c == '.').ToArray());
        return decimal.TryParse(cleaned, out var r) ? r : decimal.MaxValue;
    }

    private async Task SaveToLookbook(StyleItem item)
        => await JS.InvokeVoidAsync("saveToLookbook", item);

    private void ClearFilters()
    {
        nameFilter = "";
        colourFilter = "";
        currentSort = "";
        displayedItems = outfitItems.ToList();
    }
}