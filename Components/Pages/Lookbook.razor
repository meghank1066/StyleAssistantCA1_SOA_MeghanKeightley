@page "/lookbook"
@inject IJSRuntime JS

<h1>Your Lookbook ❤️</h1>

@if (likedItems != null && likedItems.Count > 0)
{
    <div class="product-grid">
        @foreach (var item in likedItems)
        {
            <div class="product-card">
                <strong>@item.Name</strong> - @item.Brand <br />
                <img src="@item.ImageUrl" alt="@item.Name" /><br />
                Price: @item.Price
                <button @onclick="() => RemoveItem(item)">Remove</button>
            </div>
        }
    </div>
}
else
{
<div class="empty-lookbook">
    <p>No items in your lookbook yet :(</p>
    </div>
}

@code {
    private List<StyleItem> likedItems = new();

    // loading liked items from local storage on component initialization
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            likedItems = await JS.InvokeAsync<List<StyleItem>>("localStorageHelper.getItem", "lookbook");
            StateHasChanged(); // triggers a re-render after fetching data
        }
    }

    private async Task RemoveItem(StyleItem item)
    {
        likedItems.Remove(item);
        await JS.InvokeVoidAsync("localStorageHelper.setItem", "lookbook", likedItems);
        StateHasChanged(); // updates the UI after removing an item
    }
}